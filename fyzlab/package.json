{
  "name": "fyzlab",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "FyzLab — webové fyzikální hřiště (2D sandbox pro výuku fyziky)",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
