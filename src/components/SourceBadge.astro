---
type Source = {
  label: string;
  url?: string;
  pdf?: string;
};

interface Props {
  source?: Source;
}

const { source } = Astro.props;

// `source.pdf` sborníky nejsou (a nikdy nebyly) součástí produkčního
// nasazení — public/sborniky/ je gitignored a Cloudflare je buildí z gitu
// (ověřeno: bekovo.cz/sborniky/*.pdf vrací 404). Odkazovat jde jen na
// source.url; bez něj se zdroj zobrazí jako neklikatelný štítek (viz níže).
const href = source?.url ?? null;
---
{source && (
  href ? (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      title={`Zdroj: ${source.label}`}
      class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 hover:bg-gray-200 hover:text-gray-800 transition-colors whitespace-nowrap"
    >
      <span aria-hidden="true">📖</span>
      <span>{source.label}</span>
      <span aria-hidden="true">↗</span>
    </a>
  ) : (
    <span
      title={`Zdroj: ${source.label}`}
      class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500 whitespace-nowrap"
    >
      <span aria-hidden="true">📖</span>
      <span>{source.label}</span>
    </span>
  )
)}
