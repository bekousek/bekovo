---
interface Props {
  url: string;
  title?: string;
  height?: string;
}

const { url, title = 'Google Dokument', height = '800px' } = Astro.props;
---
<div class="google-doc-embed bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" data-src={url} data-title={title} data-height={height}>
  {title && (
    <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
      <h3 class="font-medium text-gray-900">{title}</h3>
      <a
        href={url.replace('/pub?embedded=true', '/pub').replace('/preview', '/view')}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-primary-600 hover:text-primary-700"
      >
        Otevřít v novém okně ↗
      </a>
    </div>
  )}
  <div class="google-doc-embed__placeholder flex flex-col items-center gap-3 p-8 text-center">
    <p class="text-sm text-gray-600 max-w-md">
      Dokument se načte z Google Docs až po kliknutí — do té doby o návštěvě Google nic neví.
    </p>
    <button type="button" class="google-doc-embed__load-btn px-4 py-2 bg-primary-600 text-white rounded-lg text-sm font-medium hover:bg-primary-700 transition-colors">
      Načíst dokument z Google Docs
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.google-doc-embed').forEach((wrapper) => {
    const btn = wrapper.querySelector('.google-doc-embed__load-btn');
    btn?.addEventListener('click', () => {
      const src = wrapper.dataset.src;
      if (!src) return;
      const iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.width = '100%';
      iframe.style.height = wrapper.dataset.height ?? '800px';
      iframe.style.border = 'none';
      iframe.title = wrapper.dataset.title ?? 'Google Dokument';
      wrapper.querySelector('.google-doc-embed__placeholder')?.replaceWith(iframe);
    }, { once: true });
  });
</script>
