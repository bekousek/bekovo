---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SubtopicNav from '../../../components/SubtopicNav.astro';
import GoogleDocEmbed from '../../../components/GoogleDocEmbed.astro';
import EmptyState from '../../../components/EmptyState.astro';
import { getSubtopicPaths } from '../../../lib/paths';
import 'katex/dist/katex.min.css';
import '../../../styles/notebook.css';

export async function getStaticPaths() {
  return getSubtopicPaths();
}

const { topic, subtopic } = Astro.props;

const lessons = subtopic.lessonPrep?.lessons ?? null;
const googleDocUrl = subtopic.lessonPrep?.googleDocUrl ?? null;
const hasLessons = !!lessons && lessons.length > 0;
---
<BaseLayout title={`${subtopic.name} - Příprava na hodinu`} description={`Příprava na hodinu: ${subtopic.name} (${topic.name}).`}>
  <Breadcrumb items={[
    { label: topic.name, href: `/${topic.id}` },
    { label: subtopic.name, href: `/${topic.id}/${subtopic.id}` },
    { label: 'Příprava na hodinu' },
  ]} />

  <h1 class="text-2xl font-bold text-gray-900 mb-6">{subtopic.name}</h1>

  <SubtopicNav topicId={topic.id} subtopicId={subtopic.id} currentSection="priprava" />

  {hasLessons ? (
    <div class="space-y-6">
      <p class="text-sm text-gray-500">
        Zpracováno z vlastních příprav na hodinu. {lessons.length}{' '}
        {lessons.length === 1 ? 'vyučovací hodina' : lessons.length < 5 ? 'vyučovací hodiny' : 'vyučovacích hodin'}.
      </p>
      {lessons.map((lesson) => (
        <article class="lesson-block bg-white rounded-xl shadow-sm border border-gray-200 p-6 sm:p-8">
          <h2 class="lesson-title">
            <span>{lesson.title}</span>
            {lesson.date && (lesson.sourceUrl ? (
              <a class="lesson-date lesson-source" href={lesson.sourceUrl} target="_blank" rel="noopener noreferrer" title="Zobrazit originál (ručně psaná příprava) na Google Disku">{lesson.date} ↗</a>
            ) : (
              <span class="lesson-date">{lesson.date}</span>
            ))}
          </h2>
          <div class="notebook-entry prose max-w-none" set:html={lesson.content} />
        </article>
      ))}
    </div>
  ) : googleDocUrl ? (
    <GoogleDocEmbed url={googleDocUrl} title="Příprava na hodinu" />
  ) : (
    <EmptyState
      icon="📖"
      title="Příprava zatím není k dispozici"
      description="Příprava bude brzy doplněna."
    />
  )}

  <style is:global>
    .lesson-title {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0.5rem 0.75rem;
      font-size: 1.25rem;
      font-weight: 700;
      color: #1e3a8a;
      border-bottom: 2px solid #3b82f6;
      padding-bottom: 0.5rem;
      margin-bottom: 1rem;
    }
    .lesson-date {
      font-size: 0.8rem;
      font-weight: 400;
      color: #6b7280;
    }
    a.lesson-source {
      color: #2563eb;
      text-decoration: none;
      white-space: nowrap;
    }
    a.lesson-source:hover { text-decoration: underline; }

    /* Obsah hodiny — sdílí vizuální styl se "Zápisem do sešitu" (viz
       ../../../styles/notebook.css); tady jen doplňky specifické pro tuhle
       stránku (ruční přípravy mívají první nadpis hned na začátku a obrázky). */
    .notebook-entry h3:first-child { margin-top: 0; }
    .notebook-entry img { max-width: 100%; height: auto; border-radius: 0.5rem; margin: 0.75rem 0; }
    .notebook-entry figure { margin: 1.25rem 0; text-align: center; }
    .notebook-entry figure img { display: inline-block; max-width: min(100%, 440px); margin: 0 auto; }
    .notebook-entry figcaption { font-size: 0.8rem; color: #6b7280; text-align: center; margin-top: 0.25rem; }
  </style>

  {hasLessons && (
    <script>
      import katex from 'katex';

      function renderMath() {
        document.querySelectorAll('.notebook-entry').forEach((container) => {
          const html = container.innerHTML;
          if (!html.includes('$$')) return;
          container.innerHTML = html.replace(/\$\$(.*?)\$\$/g, (_, tex) => {
            try {
              return katex.renderToString(tex, { throwOnError: false, displayMode: true });
            } catch {
              return tex;
            }
          });
        });
      }

      renderMath();
      document.addEventListener('astro:page-load', renderMath);
    </script>
  )}
</BaseLayout>
