---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SubtopicNav from '../../../components/SubtopicNav.astro';
import GoogleDocEmbed from '../../../components/GoogleDocEmbed.astro';
import EmptyState from '../../../components/EmptyState.astro';
import { getSubtopicPaths } from '../../../lib/paths';

export async function getStaticPaths() {
  return getSubtopicPaths();
}

const { topic, subtopic } = Astro.props;
const tests = subtopic.pastTests || [];
---
<BaseLayout title={`${subtopic.name} - Minulé testy`}>
  <Breadcrumb items={[
    { label: topic.name, href: `/${topic.id}` },
    { label: subtopic.name, href: `/${topic.id}/${subtopic.id}` },
    { label: 'Minulé testy' },
  ]} />

  <h1 class="text-2xl font-bold text-gray-900 mb-6">{subtopic.name}</h1>

  <SubtopicNav topicId={topic.id} subtopicId={subtopic.id} currentSection="testy" />

  {tests.length > 0 ? (
    <div class="space-y-6">
      {tests.map((test) => (
        <GoogleDocEmbed url={test.googleDocUrl} title={test.title} />
      ))}
    </div>
  ) : (
    <EmptyState
      icon="📄"
      title="Zatím žádné testy"
      description="Minulé testy budou brzy doplněny."
    />
  )}
</BaseLayout>
