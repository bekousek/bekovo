---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SubtopicNav from '../../../components/SubtopicNav.astro';
import EmptyState from '../../../components/EmptyState.astro';
import NotebookExport from '../../../components/NotebookExport';
import { getSubtopicPaths } from '../../../lib/paths';

export async function getStaticPaths() {
  return getSubtopicPaths();
}

const { topic, subtopic } = Astro.props;

const latexSvg: string | null = subtopic.notebookEntry?.latexSvg ?? null;
---
<BaseLayout title={`${subtopic.name} - Zápis do sešitu`}>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />

  <Breadcrumb items={[
    { label: topic.name, href: `/${topic.id}` },
    { label: subtopic.name, href: `/${topic.id}/${subtopic.id}` },
    { label: 'Zápis do sešitu' },
  ]} />

  <h1 class="text-2xl font-bold text-gray-900 mb-6">{subtopic.name}</h1>

  <SubtopicNav topicId={topic.id} subtopicId={subtopic.id} currentSection="zapis" />

  {subtopic.notebookEntry ? (
    <div class="space-y-4">
      <NotebookExport contentId="notebook-content" client:visible />

      <div id="notebook-content" class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
        <div class="notebook-entry prose max-w-none">
          {latexSvg ? (
            <Fragment set:html={latexSvg} />
          ) : subtopic.notebookEntry.content ? (
            <Fragment set:html={subtopic.notebookEntry.content} />
          ) : (
            <p class="text-sm text-gray-500 italic">Zápis čeká na kompilaci. Spusť <code>npm run compile-latex</code>.</p>
          )}
        </div>
      </div>
    </div>
  ) : (
    <EmptyState
      icon="📝"
      title="Zápis zatím není k dispozici"
      description="Zápis bude brzy doplněn."
    />
  )}

  <style is:global>
    /* Responzivní LaTeX SVG (inline SVG z dvisvgm) */
    .notebook-entry > svg {
      width: 100%;
      height: auto;
      display: block;
    }
    .notebook-print > svg {
      width: 100%;
      height: auto;
      display: block;
      margin: 0 auto;
    }

    .notebook-entry h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1e3a8a;
      border-bottom: 2px solid #3b82f6;
      padding-bottom: 0.5rem;
      margin-bottom: 1rem;
    }
    .notebook-entry h3 {
      font-size: 1.1rem;
      font-weight: 600;
      color: #1e40af;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }
    .notebook-entry .formula {
      text-align: center;
      margin: 1rem 0;
      padding: 0.75rem;
      background: #eff6ff;
      border-radius: 0.5rem;
    }
    .notebook-entry table {
      width: 100%;
      border-collapse: collapse;
      margin: 0.75rem 0;
      font-size: 0.9rem;
    }
    .notebook-entry th {
      background: #1e40af;
      color: white;
      padding: 0.5rem 0.75rem;
      text-align: left;
      font-weight: 600;
    }
    .notebook-entry td {
      padding: 0.4rem 0.75rem;
      border-bottom: 1px solid #e5e7eb;
    }
    .notebook-entry tr:nth-child(even) td {
      background: #f9fafb;
    }
    .notebook-entry p {
      margin: 0.5rem 0;
      line-height: 1.6;
    }
    .notebook-entry ul {
      list-style: disc outside;
      padding-left: 1.25rem;
      margin: 0.5rem 0;
    }
    .notebook-entry ol {
      list-style: decimal outside;
      padding-left: 1.5rem;
      margin: 0.5rem 0;
    }
    .notebook-entry li {
      margin: 0.2rem 0;
      line-height: 1.55;
    }
    .notebook-entry li::marker {
      color: #1e40af;
    }

    /* ──────────────────────────────────────────────────────────
       LaTeX-like print stylesheet — applied ONLY to the
       off-screen render container used by NotebookExport during
       PDF generation. Web display (.notebook-entry) is untouched.
       ────────────────────────────────────────────────────────── */
    .notebook-print {
      font-family: "Charter", "Georgia", "Cambria", "Times New Roman", serif;
      font-size: 9.5pt;
      line-height: 1.35;
      color: #111;
      padding: 4mm 5mm;
      box-sizing: border-box;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .notebook-print h2 {
      font-family: system-ui, "Segoe UI", sans-serif;
      font-size: 15pt;
      font-weight: 700;
      color: #1e3a8a;
      margin: 0 0 4pt;
      padding-bottom: 2pt;
      border-bottom: 1pt solid #1e3a8a;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      text-align: center;
    }
    .notebook-print h3 {
      font-family: system-ui, "Segoe UI", sans-serif;
      font-size: 10.5pt;
      font-weight: 700;
      color: #1e40af;
      margin: 6pt 0 2pt;
    }
    .notebook-print p {
      margin: 2pt 0;
      line-height: 1.35;
    }
    .notebook-print ul,
    .notebook-print ol {
      margin: 2pt 0;
      padding-left: 13pt;
      list-style-position: outside;
    }
    .notebook-print ul { list-style-type: disc; }
    .notebook-print ol { list-style-type: decimal; }
    .notebook-print li {
      margin: 0.5pt 0;
      line-height: 1.35;
    }
    .notebook-print li::marker { color: #1e40af; }
    .notebook-print strong { font-weight: 700; }

    /* Strip colorful card backgrounds — keep as quiet bordered boxes */
    .notebook-print [style*="background:#f9fafb"],
    .notebook-print [style*="background: #f9fafb"] {
      background: #ffffff !important;
    }
    .notebook-print [style*="border-top:4px solid"],
    .notebook-print [style*="border-top: 4px solid"] {
      border-top-width: 1pt !important;
    }
    /* Tighter card padding for print */
    .notebook-print [style*="border-radius:8px"][style*="padding:0.75rem"] {
      padding: 3pt 5pt !important;
    }
    /* Force responsive auto-fit grids (e.g. teplotní stupnice cards) into a
       fixed 3-column layout for 1× layout — keeps cards on one row. The
       2× / 4× layouts override this back to single-column below. */
    .notebook-print [style*="auto-fit"] {
      grid-template-columns: repeat(3, 1fr) !important;
      gap: 4pt !important;
    }
    .notebook-print--2x [style*="auto-fit"],
    .notebook-print--4x [style*="auto-fit"] {
      grid-template-columns: 1fr !important;
    }

    /* Compact tables */
    .notebook-print table {
      width: 100%;
      border-collapse: collapse;
      font-size: 9pt;
      margin: 4pt 0;
    }
    .notebook-print th,
    .notebook-print td {
      padding: 2pt 5pt;
      border-bottom: 0.5pt solid #d1d5db;
    }
    .notebook-print th {
      background: #1e40af;
      color: #ffffff;
      font-weight: 700;
      text-align: left;
    }
    .notebook-print tr:nth-child(even) td { background: #f3f4f6; }

    /* Formulas: centered, no background tint */
    .notebook-print .formula {
      background: transparent !important;
      padding: 4pt 0 !important;
      margin: 6pt 0 !important;
      text-align: center;
    }

    /* SVG: keep aspect ratio, fit container width */
    .notebook-print svg {
      max-width: 100%;
      height: auto;
      display: block;
      margin: 4pt auto;
    }
    /* Figure-like wrappers around SVGs: drop the gray fill */
    .notebook-print [style*="background:#f9fafb"][style*="border:1px solid"] {
      background: #ffffff !important;
      border-color: #d1d5db !important;
    }

    /* KaTeX: inherit font; make sure displayMode block is centered */
    .notebook-print .katex { font-size: 1.05em; }
    .notebook-print .katex-display {
      margin: 4pt 0 !important;
    }
  </style>

  <script>
    import katex from 'katex';

    function renderMath() {
      const container = document.getElementById('notebook-content');
      if (!container) return;

      const html = container.innerHTML;
      // Replace $$...$$ with rendered KaTeX
      const rendered = html.replace(/\$\$(.*?)\$\$/g, (_, tex) => {
        try {
          return katex.renderToString(tex, { throwOnError: false, displayMode: true });
        } catch {
          return tex;
        }
      });
      container.innerHTML = rendered;
    }

    renderMath();
    document.addEventListener('astro:page-load', renderMath);
  </script>
</BaseLayout>
