---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SubtopicNav from '../../../components/SubtopicNav.astro';
import EmptyState from '../../../components/EmptyState.astro';
import SourceBadge from '../../../components/SourceBadge.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const topics = await getCollection('topics');
  const subtopicsCollection = await getCollection('subtopics');
  const activitiesCollection = await getCollection('activities');

  const paths = [];
  for (const topic of topics) {
    const topicSubtopics = subtopicsCollection.filter((s) => s.data.topicId === topic.data.id);
    for (const subtopic of topicSubtopics) {
      const activities = activitiesCollection
        .filter((a) => a.data.topicId === topic.data.id && a.data.subtopicId === subtopic.data.id)
        .map((a) => a.data);
      paths.push({
        params: { topic: topic.data.id, subtopic: subtopic.data.id },
        props: { topic: topic.data, subtopic: subtopic.data, activities },
      });
    }
  }
  return paths;
}

const { topic, subtopic, activities } = Astro.props;

const typeLabels: Record<string, string> = {
  game: 'Hra',
  method: 'Metoda',
  'group-work': 'Skupinová práce',
  other: 'Jiné',
};
---
<BaseLayout title={`${subtopic.name} - Banka aktivit`}>
  <Breadcrumb items={[
    { label: topic.name, href: `/${topic.id}` },
    { label: subtopic.name, href: `/${topic.id}/${subtopic.id}` },
    { label: 'Banka aktivit' },
  ]} />

  <h1 class="text-2xl font-bold text-gray-900 mb-6">{subtopic.name}</h1>

  <SubtopicNav topicId={topic.id} subtopicId={subtopic.id} currentSection="aktivity" />

  {activities.length > 0 ? (
    <div class="space-y-4">
      {activities.map((act) => (
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
          <div class="flex items-start gap-3">
            <span class="text-2xl">🎯</span>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-2 mb-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="font-semibold text-gray-900">{act.title}</h3>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                    {typeLabels[act.type]}
                  </span>
                </div>
                {act.source && <SourceBadge source={act.source} />}
              </div>
              <p class="text-sm text-gray-600">{act.description}</p>
              {act.driveFileUrl && (
                <a href={act.driveFileUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 mt-2 text-sm text-primary-600 hover:text-primary-700">
                  Soubor na Google Drive ↗
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <EmptyState
      icon="🎯"
      title="Zatím žádné aktivity"
      description="Aktivity budou brzy doplněny."
    />
  )}
</BaseLayout>
