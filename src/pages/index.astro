---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopicCard from '../components/TopicCard.astro';
import { getCollection } from 'astro:content';

const allTopics = await getCollection('topics');
const topics = allTopics.sort((a, b) => a.data.order - b.data.order);

const grades = [6, 7, 8, 9] as const;
const gradeLabels: Record<number, string> = {
  6: '6. třída',
  7: '7. třída',
  8: '8. třída',
  9: '9. třída',
};
---
<BaseLayout title="Fyzika pro ZŠ">
  <div class="text-center mb-10">
    <h1 class="text-3xl font-bold text-gray-900">Fyzika pro ZŠ</h1>
    <p class="mt-2 text-lg text-gray-600">Učební materiály pro 6.–9. třídu</p>
  </div>

  {grades.map((grade) => {
    const gradeTopics = topics.filter((t) => t.data.grade === grade);
    if (gradeTopics.length === 0) return null;
    return (
      <section class="mb-10">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class={`inline-block w-3 h-3 rounded-full bg-grade-${grade}`}></span>
          {gradeLabels[grade]}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {gradeTopics.map((topic) => (
            <TopicCard
              id={topic.data.id}
              name={topic.data.name}
              grade={topic.data.grade}
              icon={topic.data.icon}
              subtopicCount={topic.data.subtopics.length}
            />
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>
